# Neon Postgres connection (pooled URL — used by the app at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?channel_binding=require&sslmode=require"

# Neon Postgres direct (non-pooled) URL — used by Prisma for migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?channel_binding=require&sslmode=require"

# OpenAI API key (organization / workshop)
OPENAI_API_KEY="sk-..."
